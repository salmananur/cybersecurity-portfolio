.TESTED ON
    Date(s) Tested  : 2026-04-01
    Tested By       : Salman Nur
    Systems Tested  : Windows 11 Pro
    PowerShell Ver. :  
#>

# Ensure path exists
New-Item -Path "HKLM:\SOFTWARE\Policies\Microsoft\Windows\Installer" -Force | Out-Null

# Set correct value
Set-ItemProperty -Path "HKLM:\SOFTWARE\Policies\Microsoft\Windows\Installer" `
    -Name "AlwaysInstallElevated" `
    -Value 0 `
    -Type DWord

# Verify
Get-ItemProperty -Path "HKLM:\SOFTWARE\Policies\Microsoft\Windows\Installer"
