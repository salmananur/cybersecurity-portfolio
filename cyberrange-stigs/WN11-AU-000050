<#
.SYNOPSIS
    Configures Advanced Audit Policy to audit successful process creation events (Detailed Tracking).

.NOTES
    Author          : Salman Nur
    LinkedIn        : linkedin.com/in/salman-nur-112aa225b/
    GitHub          : github.com/salmananur
    Date Created    : 2026-04-01
    Last Modified   : 2026-04-01
    Version         : 1.0
    CVEs            : N/A
    Plugin IDs      : N/A
    STIG-ID         : WN11-AU-000050

.TESTED ON
    Date(s) Tested  : 2026-04-01
    Tested By       : Salman Nur
    Systems Tested  : 
    PowerShell Ver. :  
#>

# Ensure that subcategory settings override category settings (required for Advanced Audit Policy)
Set-ItemProperty -Path "HKLM:\SYSTEM\CurrentControlSet\Control\Lsa" `
    -Name "SCENoApplyLegacyAuditPolicy" -Value 1 -Type DWord

# Enable auditing for Process Creation successes
AuditPol.exe /set /subcategory:"Process Creation" /success:enable /failure:disable

# Verify current setting
AuditPol.exe /get /subcategory:"Process Creation"
