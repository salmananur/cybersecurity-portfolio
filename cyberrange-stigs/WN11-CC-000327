<#
.SYNOPSIS
    This PowerShell script ensures that PowerShell Transcription is enabled
    by setting the "EnableTranscripting" registry value to 1 and specifying
    a directory for transcript output. This helps monitor and audit all
    PowerShell activity for security and compliance purposes.

.NOTES
    Author          : Salman Nur
    LinkedIn        : linkedin.com/in/salman-nur-112aa225b/
    GitHub          : github.com/salmananur
    Date Created    : 2026-04-01
    Last Modified   : 2026-04-04
    Version         : 1.1
    STIG-ID         : WN11-CC-000327

.TESTED ON
    Date(s) Tested  : 2026-04-01
    Tested By       : Salman Nur
    Systems Tested  : Windows 11 Pro
#>

# WN11-CC-000327 - Enable PowerShell Transcription

$regPath = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\PowerShell\Transcription"
$valueNameEnable = "EnableTranscripting"
$valueNameOutput = "OutputDirectory"

# Desired values
$enableValue = 1
$outputDir = "C:\PowerShellTranscripts"  # Change this to a secure location or central log share

# Ensure the registry path exists
if (-not (Test-Path $regPath)) {
    New-Item -Path $regPath -Force | Out-Null
}

# Enable transcription
New-ItemProperty -Path $regPath `
    -Name $valueNameEnable `
    -Value $enableValue `
    -PropertyType DWord `
    -Force | Out-Null

# Set transcript output directory
if (-not (Test-Path $outputDir)) {
    New-Item -ItemType Directory -Path $outputDir -Force | Out-Null
}

New-ItemProperty -Path $regPath `
    -Name $valueNameOutput `
    -Value $outputDir `
    -PropertyType String `
    -Force | Out-Null

Write-Output "PowerShell Transcription enabled. Logs will be stored in $outputDir."
